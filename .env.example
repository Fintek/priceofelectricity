# PriceOfElectricity.com — Environment variables for production deployment
# Copy to .env.local for local use. Do NOT commit .env or .env.local.
# Configure these in Vercel project settings for deployment.

# Required for production (canonical site URL)
NEXT_PUBLIC_SITE_URL=https://priceofelectricity.com

# Required for production (email/alert features)
EMAIL_SINK=log

# Optional. If set, the /advertise inquiry form POSTs here (e.g. Formspree). If unset, the form composes mailto:priceofelectricity@gmail.com.
# NEXT_PUBLIC_ADVERTISER_INQUIRY_FORM_ACTION=
ALERT_EXPORT_TOKEN=your-secure-token-here
