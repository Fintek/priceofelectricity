{
  "name": "priceofelectricity",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:reset": "tsx scripts/dev-reset.ts",
    "predeploy": "tsx scripts/predeploy-check.ts",
    "release:gen": "tsx scripts/release-generate.ts",
    "build": "npm run release:gen && npm run knowledge:build && npm run knowledge:verify && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke-test.ts",
    "integrity": "node -e \"if(process.env.CI && !process.env.VERCEL){console.log('Skipping integrity in GH Actions CI');} else {process.exit(1)}\" || tsx scripts/integrity-check.ts",
    "lhci": "node -e \"if(process.env.VERCEL || process.env.CI){console.log('Skipping LHCI in CI');} else {process.exit(1)}\" || lhci autorun",
    "canonical:check": "tsx scripts/canonical-check.ts",
    "api:contract": "tsx scripts/api-contract-check.ts",
    "indexing:check": "tsx scripts/indexing-readiness.ts",
    "readiness:audit": "tsx scripts/readiness-audit.ts",
    "payload:audit": "tsx scripts/payload-audit.ts",
    "payload:baseline": "tsx scripts/payload-audit.ts --update-baseline",
    "payload:readout": "tsx scripts/payload-audit.ts --readout",
    "seo:check": "tsx scripts/seo-check.ts",
    "verify": "npm run data:validate && npm run data:check:hidden-fees && npm run lint && npm run typecheck && npm run build && npm run payload:audit && npm run canonical:check && npm run smoke && npm run integrity && npm run api:contract && npm run indexing:check && npm run readiness:audit && npm run seo:check && npm run lhci",
    "verify:vercel": "npm run data:validate && npm run data:check:hidden-fees && npm run lint && npm run typecheck && npm run build && npm run payload:audit && npm run canonical:check && npm run smoke && npm run integrity && npm run api:contract && npm run indexing:check && npm run readiness:audit && npm run seo:check",
    "data:validate": "tsx scripts/data-validate.ts",
    "data:build": "tsx scripts/data-build.ts",
    "data:build:hidden-fees": "tsx scripts/data-build-hidden-fees.ts",
    "data:check:hidden-fees": "tsx scripts/data-build-hidden-fees.ts --check",
    "data:diff": "tsx scripts/data-diff.ts",
    "data:update:eia:res": "tsx scripts/eia/update_residential_monthly.ts",
    "data:apply:corrections": "tsx scripts/eia/apply-corrections.ts",
    "data:check:mom": "tsx scripts/eia/check-mom-anomaly.ts",
    "data:backfill:eia:res": "tsx scripts/eia/backfill_residential_monthly.ts",
    "data:build:snapshots:eia": "tsx scripts/eia/generate_snapshots_from_eia_csv.ts",
    "knowledge:build": "tsx scripts/knowledge-build.ts",
    "knowledge:verify": "node scripts/verify-knowledge.js",
    "knowledge:integrity": "node scripts/verify-knowledge.js --integrity-only",
    "knowledge:types": "node scripts/knowledge-types.js",
    "knowledge:check": "node scripts/knowledge-check.js",
    "launch:check": "npm run build",
    "map:build": "node scripts/build-state-map-paths.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/server-github": "^2025.4.8",
    "@playwright/mcp": "^0.0.68",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/postcss": "^4",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "d3-geo": "^3.1.1",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "topojson-client": "^3.1.0",
    "topojson-simplify": "^3.0.3",
    "us-atlas": "^3.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
